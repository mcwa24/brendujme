{
  "name": "brendujme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "logos:cache": "tsx scripts/cache-brand-logos.ts",
    "logos:install": "python3 scripts/install-brand-logo.py",
    "logos:repair": "python3 scripts/repair-brand-logos.py",
    "logos:sync-official": "echo 'Sync isključen — logoi se unose ručno (logos:install).' && exit 1",
    "logos:remiks": "tsx scripts/cache-remiks-brand-logos.ts",
    "logos:office": "tsx scripts/cache-office-brand-logos.ts",
    "scrape:office": "tsx scripts/scrape-office-shoes.ts",
    "db:seed:office": "tsx --env-file=.env.local scripts/seed-office-shoes.ts",
    "scrape:nike": "tsx scripts/scrape-nike-serbia.ts",
    "db:seed:nike": "tsx --env-file=.env.local scripts/seed-nike-serbia.ts",
    "scrape:buzz": "tsx scripts/scrape-buzz-sneakers.ts",
    "scrape:tike": "tsx scripts/scrape-tike.ts",
    "db:seed:tike": "tsx --env-file=.env.local scripts/seed-tike.ts",
    "db:seed:buzz": "tsx --env-file=.env.local scripts/seed-buzz-sneakers.ts",
    "scrape:djak": "tsx scripts/scrape-djak-sport.ts",
    "db:seed:djak": "tsx --env-file=.env.local scripts/seed-djak-sport.ts",
    "scrape:sport-vision": "tsx scripts/scrape-sport-vision.ts",
    "db:seed:sport-vision": "tsx --env-file=.env.local scripts/seed-sport-vision.ts",
    "scrape:planeta": "tsx scripts/scrape-planeta-sport.ts",
    "db:seed:planeta": "tsx --env-file=.env.local scripts/seed-planeta-sport.ts",
    "scrape:fashion": "tsx scripts/scrape-fast-fashion-serbia.ts",
    "scrape:beauty": "tsx scripts/scrape-beauty-retail-serbia.ts",
    "scrape:tech": "tsx scripts/scrape-tech-retail-serbia.ts",
    "build:fashion-sport": "tsx scripts/build-fashion-sport-scraped.ts",
    "build:home": "tsx scripts/build-home-retail-scraped.ts",
    "data:prepare": "tsx scripts/prepare-imported-data.ts",
    "promotions:detect": "tsx --env-file=.env.local scripts/detect-retailer-promotions.ts",
    "db:seed:promotions": "tsx --env-file=.env.local scripts/seed-promotions-only.ts",
    "centers:cache": "tsx scripts/cache-shopping-center-logos.ts",
    "logos:retailers": "tsx scripts/cache-retailer-logos.ts",
    "db:seed": "npm run data:prepare && tsx --env-file=.env.local scripts/seed-supabase-v2.ts",
    "db:sync:retailers": "tsx --env-file=.env.local scripts/sync-retailer-copy.ts",
    "verify:retailers": "tsx scripts/verify-retailer-alignment.ts",
    "db:sync": "npm run db:seed",
    "db:seed:legacy": "tsx --env-file=.env.local scripts/seed-supabase.ts",
    "assets:upload": "tsx --env-file=.env.local scripts/upload-photos-to-supabase.ts",
    "assets:sync": "npm run logos:remiks && npm run assets:upload"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.40.0",
    "geist": "^1.7.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^4.8.0",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "playwright": "^1.52.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
